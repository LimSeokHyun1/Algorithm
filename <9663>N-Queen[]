#include <iostream>
#include <string.h>

using namespace std;

int N, result = 0;

void Set(int** board, int x, int y, int depth){
	int tx, ty;
	for(int i = 0; i < N; i++){
		if(board[x][i] == 0)
			board[x][i] = depth;
	}
	for(int i = 0; i < N; i++){
		if(board[i][y] == 0)
			board[i][y] = depth;
	}
	tx = x;
	ty = y;
	while((tx >= 0 && tx < N) && (ty >= 0 && ty < N)){
		if(board[tx][ty] == 0)
			board[tx][ty] = depth;
		tx--;
		ty--;
	}
	tx = x;
	ty = y;
	while((tx >= 0 && tx < N) && (ty >= 0 && ty < N)){
		if(board[tx][ty] == 0)
			board[tx][ty] = depth;
		tx++;
		ty++;
	}
	tx = x;
	ty = y;
	while((tx >= 0 && tx < N) && (ty >= 0 && ty < N)){
		if(board[tx][ty] == 0)
			board[tx][ty] = depth;
		tx++;
		ty--;
	}
	tx = x;
	ty = y;
	while((tx >= 0 && tx < N) && (ty >= 0 && ty < N)){
		if(board[tx][ty] == 0)
			board[tx][ty] = depth;
		tx--;
		ty++;
	}
}

void NQueen(int** board, int queen){
	cout << endl;
	cout << endl;
	for(int i = 0; i < N; i++){
		for(int j = 0; j < N; j++){
			cout << board[i][j] << " ";
		}
		cout << endl;
	}
	
	if(queen == 0){
		result++;
		return;
	}
	for(int i = 0; i < N; i++){
		for(int j = 0; j < N; j++){
			if(board[i][j] == 0){
				Set(board, i, j, queen);
				NQueen(board, queen - 1);
				
				for(int a = 0; a < N; a++){
					for(int b = 0; b < N; b++){
						if(board[a][b] == queen - 1){
							board[a][b] = 0;
						}
					}
				}
				
			}
		}
	}
	return;
}

int main(){
	int** board;
	cin >> N;
	
	board = new int*[N];
	for(int i = 0; i < N; i++){
		board[i] = new int[N];
	}
	for(int i = 0; i < N; i++){
		memset(board[i], 0, sizeof(int) * N);
	}


	NQueen(board, N);
	cout << result << "\n";
	
	for(int i = 0; i < N; ++i){
		delete[] board[i];
	}
	delete[] board;
	
