#include <iostream>

#define INF	987654321

using namespace std;

int soobin, sister, result = INF;

void Find_Min_Time_To_Meet(int time){
	if(time > result) return;
	if(soobin == sister){
		if(result > time)	result = time;
		return;
	}
	if(soobin < sister){
		soobin *= 2;
		Find_Min_Time_To_Meet(time + 1);
		soobin /= 2;
		
		soobin++;
		Find_Min_Time_To_Meet(time + 1);
		--soobin;
	}
	
	
	--soobin;
	Find_Min_Time_To_Meet(time + 1);
	soobin++;
}

int main(){
	cin.tie(NULL);
	ios::sync_with_stdio(0);
	
	int time = 0;
	cin >> soobin >> sister;
	Find_Min_Time_To_Meet(time);
	cout << result << "\n";
}

