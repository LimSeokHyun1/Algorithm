#include <iostream>
#include <vector>

#define INF 987654321

using namespace std;

class Vertex{
	public:
		int index;
		int dist;
		int prior;
	Vertex(int index, int dist, int prior) : index(index), dist(dist), prior(prior){
	}
	Vertex(){	// 배열 만드려면 이 생성자 필요. (아니면 default값을 넣어주던가)
		index = 0;
		dist = 0;
		prior = 0;
	}
};

class PriorityQueue{
	private:
		Vertex* heap;
		int rear;
		int size;
	public:
		PriorityQueue(int vertices, int start){
			this->size = vertices * vertices;
			heap = new Vertex[this->size];
			rear = 0;
			
			for(int i = 1; i <= vertices; i++){
				if(i == start){
					Push(i, 0, -1);
				}
				else{
					Push(i, INF, -1);
				}
			}
		}
		void PrintQueue(){
			for(int i = 1; i <= rear; i++){
				if(heap[i].index != 0){
					if(heap[i].dist == INF){
						cout << heap[i].index << " :" << "INF" << " :" << heap[i].prior << endl;
					}
					else{
						cout << heap[i].index << " :" << heap[i].dist << " :" << heap[i].prior << endl;
					}
				}
			}
			cout << endl << endl;
		}
		void Swap(Vertex* a, Vertex* b){
			Vertex tmp = *a;
			*a = *b;
			*b = tmp;
			
		}
		void Push(int index, int dist, int prior){
			heap[++rear].index = index;	// index는 1부터 시작.
			heap[rear].dist = dist;
			heap[rear].prior = prior;
			int child = rear;
			int parent = child / 2;
			while(child > 1 && heap[child].dist < heap[parent].dist){
				Swap(&heap[child], &heap[parent]);
				child = parent;
				parent = child / 2;
			}
		}
		Vertex Pop(){
			Vertex result = heap[1];
			Swap(&heap[1], &heap[rear]);
			rear--;
			
			int parent = 1;
			int child = 2;
			if(rear >= 3){
				if(heap[2].dist > heap[3].dist){
					child = 3;
				}
			}
			while(child <= rear && heap[child].dist < heap[parent].dist){
				Swap(&heap[parent], &heap[child]);
				parent = child;
				child = 2 * parent;
				if(child < rear){
					if(heap[child].dist > heap[child + 1].dist){
						child++;
					}
				}
			}
			
			return result;
		}
};

class Graph{
	private:
		vector<vector<int>> matrix;
		int vertices;
		int edges;
		int start;
	
	public:
		Graph(int vertices, int edges, int start){
			this->vertices = vertices;
			this->edges = edges;
			this->start = start;
			matrix.resize(vertices, vector<int>(vertices, 0));
		}
		void ShowGraph(){
			for(int i = 0; i < vertices; i++){
				for(int j = 0; j < vertices; j++){
					cout << matrix[i][j] << " " ;
				}
				cout << endl;
			}
			cout << endl;
		}
		void SetGraph(){
			int u, v, w;
			for(int i = 0; i < edges; i++){	// u -> v
				cin >> u >> v >> w;
				matrix[u-1][v-1] = w;
			}
		}
};

int main(int argc, char* argv[]) {
	int vertices, edges, start;
	cin >> vertices >> edges >> start;
	Graph* graph = new Graph(vertices, edges, start); 
	graph->SetGraph();
	graph->ShowGraph();
	
	PriorityQueue* priorityqueue = new PriorityQueue(vertices, start);
	priorityqueue->PrintQueue();
	priorityqueue->Push(1, 4, 1);
	priorityqueue->PrintQueue();
	priorityqueue->Push(2, 1, 1);
	priorityqueue->Pop();
	priorityqueue->PrintQueue();
	priorityqueue->Pop();
	priorityqueue->PrintQueue();
	
	delete graph;
	return 0;
}

