#include <iostream>
#include <cstring>

using namespace std;

char board[20][20];
char visited[20][20];
char pre[26];
int R, C;

int DFS(int i, int j, int result){	// 1. 초기화 문제, 2. result 갱신 문제
	visited[i][j] = 1;
	pre[board[i][j] - 65] = 1;
	int temp = 0;
	
	if(i - 1 >= 0 && visited[i - 1][j] == 0 && pre[board[i - 1][j] - 65] == 0){ // 상
		temp = DFS(i - 1, j, ++result);
		if(result < temp) result = temp;
		visited[i - 1][j] = 0;
		pre[board[i - 1][j] - 65] = 0;
	}
	if(i + 1 < R && visited[i + 1][j] == 0 && pre[board[i + 1][j] - 65] == 0){ // 하
		temp = DFS(i + 1, j, ++result);
		if(result < temp) result = temp;
		visited[i + 1][j] = 0;
		pre[board[i + 1][j] - 65] = 0;
	}
	if(j - 1 >= 0 && visited[i][j - 1] == 0 && pre[board[i][j - 1] - 65] == 0){ // 좌
		temp = DFS(i, j - 1, ++result);
		if(result < temp) result = temp;
		visited[i][j - 1] = 0;
		pre[board[i][j - 1] - 65] = 0;
	}
	if(j + 1 < C && visited[i][j + 1] == 0 && pre[board[i][j + 1] - 65] == 0){ // 우
		temp = DFS(i, j + 1, ++result);
		if(result < temp) result = temp;
		visited[i][j + 1] = 0;
		pre[board[i][j + 1] - 65] = 0;
	}
	return result;
}

int main(){
	int result = 0;	// R: 세로, C: 가로
	char alphabet;
	for(int i = 0; i < 20; i++){
		memset(board[i], 0, sizeof(char) * 20);
		memset(visited[i], 0, sizeof(char) * 20);
	}
	memset(pre, 0, sizeof(char) * 26);
	
	cin >> R >> C;
	for(int i = 0; i < R; i++){
		for(int j = 0; j < C; j++){
			cin >> alphabet;
			board[i][j] = alphabet;
		}
	}
	
	cout << DFS(0, 0, result) << "\n";
	
}
